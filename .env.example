# Frontend (Vite) — safe to expose (anon key is public, protected by RLS)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# App config
VITE_ADMIN_EMAIL=dirk.aporius@bms-cs.de

